# === Required ===
PRIVATE_KEY=0x...                       # Wallet private key (env / smart-account modes)

# === Chain ===
DEFAULT_CHAIN_ID=84532                  # Base Sepolia (testnet)
RPC_URL=https://sepolia.base.org        # Default chain RPC
# RPC_URL_1=https://eth.llamarpc.com    # Per-chain RPC (optional)
# RPC_URL_8453=https://mainnet.base.org

# === Wallet Mode ===
WALLET_MODE=env                         # env | browser | smart-account | session-key

# === HTTP ===
WALLET_PORT=18420                       # HTTP server port
WALLET_AUTH_TOKEN=                      # Empty = auto-generate on startup

# === Policy ===
WALLET_POLICY=                          # Path to wallet-policy.json (optional)

# === Storage ===
WALLET_STORE=sqlite                     # memory | sqlite
WALLET_DB=./vaulx.db                    # SQLite file path

# === Withdraw ===
WITHDRAW_TO=                            # Default withdraw destination

# === Smart Account (smart-account / session-key modes) ===
PIMLICO_API_KEY=                        # Pimlico API key (free for testnets)
SMART_ACCOUNT_ADDRESS=                  # Deployed smart account (session-key mode)
SESSION_KEY=                            # Session private key (session-key mode)
# BUNDLER_URL=                          # Custom bundler (overrides Pimlico)
# PAYMASTER_URL=                        # Custom paymaster (overrides Pimlico)

# === DeFi ===
ENABLE_SWAP=false                       # Enable swap_token tool
# CUSTOM_TOKENS=./custom-tokens.json    # Custom token registry
