# === Required ===
PRIVATE_KEY=0x...                     # Wallet private key
DEFAULT_CHAIN_ID=84532                # Base Sepolia (testnet)
RPC_URL=https://sepolia.base.org      # RPC endpoint

# === Optional ===
WALLET_POLICY=./wallet-policy.json    # Spending policy file path
WALLET_PORT=18420                     # HTTP port (default: 18420)
WALLET_AUTH_TOKEN=                    # Empty = auto-generate on startup
WITHDRAW_TO=0x...                     # Withdraw destination address
